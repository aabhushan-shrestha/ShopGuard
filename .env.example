# ── Supabase (required for cloud sync) ────────────────────────────────────────
# Get these from: Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key        # anon key — RLS restricts access

# Stable identifier for this store PC (stored as store_id in Supabase)
STORE_ID=store_1

# ── Telegram (optional, for on-site staff alerts) ─────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
