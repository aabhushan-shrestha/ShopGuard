# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key   # service role key (not anon key)

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-before-deploying

# Secret used by agents to self-register on first boot
AGENT_REGISTER_SECRET=change-me

# Supabase Storage bucket name for clips
CLIPS_BUCKET=clips
